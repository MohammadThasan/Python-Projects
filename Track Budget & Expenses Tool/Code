import os

# =============================================
# BUDGET TRACKER - BEGINNER VERSION
# =============================================

# ------------------- SECTION 1: GLOBAL SETUP -------------------
# DESCRIPTION:
# We create our variables here. 'expenses' stores your items,
# and 'monthly_budget' stores your spending limit.

# LEARNER NOTE: A list [] is like a shopping basket. We keep adding things to it!
expenses = []

# LEARNER NOTE: A float is a number with a decimal point (like 5.50 or 0.0).
monthly_budget = 0.0

# LEARNER NOTE: These are strings that point to the names of our text files.
FILE_NAME = "expenses.csv"
BUDGET_FILE = "budget.txt"

# ------------------- SECTION 2: LOAD AND SAVE -------------------
# DESCRIPTION:
# These functions handle the computer's memory.
# Data is saved as: Date,Category,Amount,Description


def load_data():
    """Gets your saved data back when you start the program."""
    global expenses, monthly_budget

    # --- TASK 1: Load the Expenses CSV ---
    # LEARNER NOTE: We check if the file exists so the program doesn't crash!
    if os.path.exists(FILE_NAME):
        # LEARNER NOTE: "r" stands for Read mode.
        f = open(FILE_NAME, "r")
        for line in f:
            # LEARNER NOTE: .strip() removes the hidden "Enter" at the end of each line
            line = line.strip()
            if line == "":
                continue
            # LEARNER NOTE: .split(",") turns "date,cat,amt,desc" into a list
            parts = line.split(",")
            if len(parts) == 4:
                try:
                    # We save it as a 'Dictionary' (data with labels)
                    new_item = {
                        "date": parts[0],
                        "category": parts[1],
                        "amount": float(parts[2]),  # Turn text back into a number!
                        "description": parts[3],
                    }
                    expenses.append(new_item)
                except ValueError:
                    print(
                        "Skipping a line in "
                        + FILE_NAME
                        + " because it has a bad amount."
                    )
        f.close()
        print("Past expenses loaded!")

    # --- TASK 2: Load the Budget Limit ---
    if os.path.exists(BUDGET_FILE):
        f = open(BUDGET_FILE, "r")
        val = f.read().strip()
        if val != "":
            # Store the saved number back into our monthly_budget variable
            monthly_budget = float(val)
        f.close()


def save_data():
    """Saves everything to files so you don't lose your work."""
    # Save Expenses
    f = open(FILE_NAME, "w")
    for item in expenses:
        row = (
            item["date"]
            + ","
            + item["category"]
            + ","
            + str(item["amount"])
            + ","
            + item["description"]
            + "\n"
        )
        f.write(row)
    f.close()

    # Save Budget
    f = open(BUDGET_FILE, "w")
    f.write(str(monthly_budget))
    f.close()

    print("Everything is saved to " + FILE_NAME)


# ------------------- SECTION 3: BUDGET LOGIC -------------------
# DESCRIPTION:
# This part handles setting and tracking your limit.


def set_budget():
    """Step 3: Function to input monthly budget."""
    global monthly_budget
    print("\n--- SET MONTHLY BUDGET ---")

    # Requirement: Prompt for total amount
    val = input("Enter the total amount you want to budget for the month: ")

    try:
        monthly_budget = float(val)
        print("Budget set successfully.")
    except ValueError:
        print("Error: Please enter a valid number.")


def calculate_total():
    """Adds up every expense in our list."""
    total = 0.0
    for item in expenses:
        total = total + item["amount"]
    return total


def track_budget():
    """Step 3: Function to calculate total and compare with budget."""
    global monthly_budget
    print("\n--- TRACK BUDGET ---")

    # If no budget is set, we must set it first
    if monthly_budget == 0:
        print("No budget set yet! Please set one first.")
        set_budget()
        if monthly_budget == 0:
            return

    # Calculate current values
    total_spent = calculate_total()

    # 1. Show the current status lines
    print("Current Budget: $" + str(monthly_budget))
    print("Monthly Budget: " + str(monthly_budget))

    if total_spent > monthly_budget:
        print("You have exceeded your budget!")
    else:
        balance = monthly_budget - total_spent
        print("You have " + str(balance) + " left for the month")

    print("Total Spent so far: " + str(total_spent))

    # 2. Ask for update at the very end
    choice = input("Do you want to update it? (y/n): ").strip().lower()
    if choice == "y":
        set_budget()


# ------------------- SECTION 4: EXPENSE MANAGEMENT -------------------


def add_expense():
    """Asks for 4 details to create a new expense."""
    print("\n--- ADD NEW EXPENSE ---")

    # Prompt for expense details
    date = input("Enter date (YYYY-MM-DD): ")
    category = input("Enter category (e.g., Food, Travel): ")
    amt_text = input("Enter amount ($): ")

    if amt_text == "":
        print("Error: Amount cannot be empty.")
        return

    try:
        amt_num = float(amt_text)
        description = input("Enter description: ")

        # LEARNER NOTE: We "Package" the data into a dictionary {}
        new_item = {
            "date": date,
            "category": category,
            "amount": amt_num,
            "description": description,
        }
        expenses.append(new_item)
        print("Expense added successfully!")
    except ValueError:
        print("Error: That's not a valid number.")


def view_expenses():
    """Shows every expense in a table."""
    print("\n--- ALL EXPENSES ---")

    # LEARNER NOTE: len() checks the size of our list.
    if len(expenses) == 0:
        print("There is nothing in the list.")
        return

    print("DATE       | CATEGORY   | AMOUNT | DESCRIPTION")
    print("-" * 50)

    for item in expenses:
        # STEP 1: Check if any part of the expense is missing
        # We manually check the keys to make it very clear for a beginner
        if (
            "date" not in item
            or "category" not in item
            or "amount" not in item
            or "description" not in item
        ):
            print("Notice: Skipping an incomplete entry (missing data).")
            continue

        # STEP 2: Make sure the values aren't empty
        if item["date"] == "" or item["category"] == "" or item["description"] == "":
            print("Notice: Skipping an entry with empty details.")
            continue

        # STEP 3: Make sure the amount is a positive number
        if item["amount"] <= 0:
            print("Notice: Skipping an entry with zero or negative cost.")
            continue

        d = item["date"]
        c = item["category"]
        a = str(item["amount"])
        desc = item["description"]
        print(d.ljust(10) + " | " + c.ljust(10) + " | $" + a.ljust(6) + " | " + desc)


# ------------------- SECTION 5: THE INTERACTIVE MENU -------------------


def show_menu():
    """Main menu of the program."""
    # STEP 1: Always load data as soon as the app opens!
    load_data()

    # STEP 2: Start a loop so the app stays open.
    while True:
        print("\n===== BUDGET TRACKER MENU =====")
        print("1. Add Expense")
        print("2. View Expenses")
        print("3. Track Budget")
        print("4. Save Expenses")
        print("5. Exit")

        # Select an option
        pick = input("Select an option (1-5): ").strip()

        if pick == "1":
            add_expense()
        elif pick == "2":
            view_expenses()
        elif pick == "3":
            track_budget()
        elif pick == "4":
            save_data()
        elif pick == "5":
            # Save data before exiting
            save_data()
            print("Budget data saved. Goodbye!")
            break
        else:
            print("Invalid choice! Try numbers 1 to 5.")


if __name__ == "__main__":
    show_menu()
